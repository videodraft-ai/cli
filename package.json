{
  "name": "videodraft",
  "version": "0.1.1",
  "description": "Official VideoDraft CLI — create AI videos, images, voiceovers and music from your terminal. Agent-friendly: --json everywhere, stable exit codes, async job polling.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://videodraft.ai/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/videodraft-ai/cli.git"
  },
  "bugs": "https://github.com/videodraft-ai/cli/issues",
  "keywords": [
    "videodraft",
    "ai",
    "video",
    "video-generation",
    "image-generation",
    "cli",
    "agent",
    "mcp"
  ],
  "bin": {
    "videodraft": "./dist/index.js"
  },
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=20.18.1"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && node test/e2e-mock.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.2",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.0"
  }
}
